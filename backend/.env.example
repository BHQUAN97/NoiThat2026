# NEVER commit real secrets. Copy to .env and fill.

# Server
PORT=4002
NODE_ENV=development

# Database (MySQL local port 3307 — tránh conflict VietNet 3306)
DB_HOST=localhost
DB_PORT=3309
DB_USERNAME=noithat
DB_PASSWORD=<CHANGE_ME_MYSQL_APP_PASSWORD>
DB_NAME=noithat2026

# JWT — MUST be >=32 chars. Generate: openssl rand -base64 32
JWT_SECRET=<CHANGE_ME_GENERATE_WITH_openssl_rand_base64_32>
JWT_EXPIRATION=3600
REFRESH_TOKEN_EXPIRATION=604800

# R2 Storage (Cloudflare)
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET_PRIVATE=noithat-private
R2_BUCKET_PUBLIC=noithat-public
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# Resend Email
RESEND_API_KEY=
MAIL_FROM=Noi That Duy Manh <noreply@duymanhnoithat.vn>
ADMIN_EMAIL=duymanhnoithat@gmail.com

# CORS
ALLOWED_ORIGINS=http://localhost:8082

# Frontend URL (dùng cho link password reset trong email)
FRONTEND_URL=http://localhost:8082

# Logging
LOG_LEVEL=debug
